# Groq — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# Supabase — https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here   # Never expose to browser

# Supabase public (for browser client — optional unless adding client-side reads)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# HuggingFace — https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Admin Panel Password (server-side only)
ADMIN_PANEL_PASSWORD=your_secure_password_here

# Embedding Configuration (REQUIRED for production)
# MUST be set to 'false' for Vercel/serverless deployment
# Set to 'true' only for local development with @xenova/transformers installed
# Default behavior: Uses HuggingFace API (recommended for production)
USE_LOCAL_EMBEDDINGS=false
