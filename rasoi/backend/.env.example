# ── RasOI Backend Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.

# Claude API key (required — Vision + recipe generation + substitutions)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Recipe APIs (optional — app falls back to Claude if keys are missing)
SPOONACULAR_API_KEY=
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# Database
DATABASE_URL=sqlite:///./rasoi.db

# Server
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
